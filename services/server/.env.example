# Copy to .env, fill in for your deploy. .env is gitignored.
#
# The relay is now a *pure prover* — it never touches Stellar.
# It receives a transcript + player strkey, runs flight-host locally,
# returns the resulting seal + journal. The browser's wallet signs the
# on-chain submit_score and pays the gas.

# HTTP listen port.
PORT=8787

# Path to the compiled flight-host binary (built via `cargo build --release
# --bin flight-host` from repo root). The relay spawns this per request.
FLIGHT_HOST_BIN=../../target/release/flight-host

# Per-pubkey cooldown between prove requests, in seconds. Prevents one
# player from spamming the relay's CPU. 0 disables.
SUBMIT_COOLDOWN_SECONDS=60
