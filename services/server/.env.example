# Copy to .env, fill in for your deploy. .env is gitignored.

# HTTP listen port.
PORT=8787

# SQLite path. Bun creates it on first run.
DB_PATH=./.data/relay.db

# Bearer token workers must present on /api/worker/* requests.
# Generate one with: openssl rand -hex 32
WORKER_API_KEY=

# Stellar network the relay submits txs on. testnet | mainnet
NETWORK=testnet

# Soroban RPC endpoint. Override per network.
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Deployed game_hub contract id (C...). From .deploy-state.<network>.
GAME_HUB_CONTRACT_ID=

# Relay's own Stellar secret key (S...). Pays gas for submit_score txs.
# This account does NOT need any admin role on the contract — submit_score
# is permissionless. It just needs XLM for fees.
RELAY_SECRET_KEY=

# game_id the relay submits scores against. flight_scroll = 1.
GAME_ID=1
