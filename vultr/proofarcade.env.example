# Copy to /etc/proofarcade.env on the Vultr box (chmod 600).
# systemd unit reads this via EnvironmentFile= (vultr/proofarcade-relay.service).

# --- Relay (Bun server) ---
PORT=8080
FLIGHT_HOST_BIN=/opt/proofarcade/target/release/flight-host
SUBMIT_COOLDOWN_SECONDS=60
CORS_ORIGIN=https://proofarcade.xyz

# --- Proving mode ---
# groth16 | stark | stub | boundless
PROVE_MODE=boundless
VERIFIER_SELECTOR_HEX=73c457ba

# --- Boundless (required when PROVE_MODE=boundless) ---
# ethereum-sepolia | base-sepolia | base-mainnet | ethereum-mainnet
BOUNDLESS_NETWORK=base-mainnet
# 0x-prefixed hex. Wallet must be funded with ETH on Base Mainnet.
BOUNDLESS_PRIVATE_KEY=0x________________________________________________________________
# Optional override; defaults to https://mainnet.base.org if unset.
# BOUNDLESS_RPC_URL=
PINATA_JWT=

# --- GitHub leaderboard dispatch ---
GITHUB_DISPATCH_TOKEN=
GITHUB_REPO=enderNakamoto/flight_runner
REFRESH_DEBOUNCE_SECONDS=20
